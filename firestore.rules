rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required, 1-100 chars)
    //   - email: string (required, email format)
    //   - projectTitle: string (optional, 1-200 chars)
    //   - createdAt: timestamp (required)
    //
    // Collection: logs
    // Document ID: {logId} (Auto-generated)
    // Fields:
    //   - weekNumber: number (required, 1-52)
    //   - description: string (required, 1-1000 chars)
    //   - evidenceUrl: string (required, URL)
    //   - evidenceName: string (optional)
    //   - evidenceType: string (optional)
    //   - studentId: string (required, matches Auth UID)
    //   - studentName: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isUnsratEmail(email) {
      return email is string && email.matches(".*[@.]unsrat\\.ac\\.id$");
    }

    function isAuthenticated() {
      return request.auth != null && isUnsratEmail(request.auth.token.email);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "wisard.kalengkongan@unsrat.ac.id" && request.auth.token.email_verified == true));
    }

    function isValidEmail(email) {
      return email is string && email.matches("^[a-zA-Z0-9._%+-]+@([a-zA-Z0-9.-]+\\.)?unsrat\\.ac\\.id$");
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             isValidEmail(data.email) &&
             data.createdAt is timestamp &&
             (!('role' in data) || data.role in ['admin', 'student']);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['weekNumber', 'description', 'evidenceUrl', 'studentId', 'studentName', 'groupId', 'timestamp']) &&
             data.weekNumber is number && data.weekNumber >= 1 && data.weekNumber <= 52 &&
             data.description is string && data.description.size() >= 1 && data.description.size() <= 1000 &&
             isValidUrl(data.evidenceUrl) &&
             data.studentId == request.auth.uid &&
             data.studentName is string &&
             data.groupId is string &&
             data.timestamp is timestamp;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'members', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.members is list &&
             data.createdAt is timestamp;
    }

    function isGroupMember(groupId) {
      return isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members || isAdmin());
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'student');
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    (isAdmin() || !('role' in request.resource.data) || request.resource.data.role == resource.data.role);
    }

    match /logs/{logId} {
      allow read: if isAuthenticated() && (isGroupMember(resource.data.groupId) || isAdmin());
      allow create: if isAuthenticated() && isValidLog(request.resource.data) && 
                    request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.members;
      allow update: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isAdmin()) && isValidLog(request.resource.data) &&
                    request.resource.data.studentId == resource.data.studentId &&
                    request.resource.data.groupId == resource.data.groupId &&
                    request.resource.data.timestamp == resource.data.timestamp;
      allow delete: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isAdmin());
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidGroup(request.resource.data);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
